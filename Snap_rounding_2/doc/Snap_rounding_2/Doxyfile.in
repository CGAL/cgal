@INCLUDE = ${CGAL_DOC_PACKAGE_DEFAULTS}

PROJECT_NAME = "CGAL ${CGAL_DOC_VERSION} - 2D Snap Rounding"

# custom options for this package
HIDE_UNDOC_CLASSES         =  true
WARN_IF_UNDOCUMENTED       =  false


INPUT += ${CGAL_PACKAGE_INCLUDE_DIR}/CGAL/vertical_slab_snap_rounding_2.h \
         ${CGAL_PACKAGE_INCLUDE_DIR}/CGAL/Double_grid_snap_rounding_traits_2.h \
         ${CGAL_PACKAGE_INCLUDE_DIR}/CGAL/Float_grid_snap_rounding_traits_2.h \
         ${CGAL_PACKAGE_INCLUDE_DIR}/CGAL/Integer_grid_snap_rounding_traits_2.h \
         ${CGAL_PACKAGE_INCLUDE_DIR}/CGAL/hot_pixel_snap_rounding_2.h \
         ${CGAL_PACKAGE_INCLUDE_DIR}/CGAL/Hot_pixel_snap_rounding_traits_2.h \
         ${CGAL_PACKAGE_INCLUDE_DIR}/CGAL/Snap_rounding_2.h \
         ${CGAL_PACKAGE_INCLUDE_DIR}/CGAL/Snap_rounding_traits_2.h
